# OpenWA Configuration (required)
OPENWA_BASE_URL=http://localhost:2785
OPENWA_API_TOKEN=owa_k1_your_token_here

# OpenRouter Configuration (required)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
# Optional: model to use (default: google/gemini-2.5-flash)
OPENROUTER_MODEL=google/gemini-2.5-flash

# Supabase Configuration (required for memory)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin security (required for /api/admin/* endpoints)
ADMIN_SECRET=a_strong_random_string_here

# Business Information (used in system prompt)
BUSINESS_NAME=اسم الشركة
BUSINESS_DESCRIPTION=وصف مختصر للشركة
BUSINESS_HOURS=السبت - الأربعاء 9:00 ص - 5:00 م
BUSINESS_TONE=محترف ومهذب
