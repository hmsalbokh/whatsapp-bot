# OpenRouter (required — get your key at https://openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-v1-YOUR_KEY_HERE"

# OpenWA (required for WhatsApp — your OpenWA instance URL and API token)
OPENWA_BASE_URL="http://localhost:2785"
OPENWA_API_TOKEN="owa_k1_YOUR_TOKEN_HERE"

# Optional: override the default model
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Supabase (required for persistent storage)
SUPABASE_URL="https://txjnajmqrwuanbufkjxt.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# Supabase Auth (required for authentication)
NEXT_PUBLIC_SUPABASE_URL="https://txjnajmqrwuanbufkjxt.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Site URL (used for auth redirects — change in production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# n8n Sidecar (optional — webhook URL for n8n workflow automation)
N8N_WEBHOOK_URL=""

# Sidecar API Key (required for /api/sidecar/n8n and /api/integrations/webhook)
# Generate a random key: openssl rand -hex 32
SIDECAR_API_KEY=""
INTEGRATION_API_KEY=""
