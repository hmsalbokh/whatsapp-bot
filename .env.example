# OpenRouter (required — get your key at https://openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-v1-YOUR_KEY_HERE"

# OpenWA (required — your OpenWA instance URL and API token)
OPENWA_BASE_URL="http://localhost:2785"
OPENWA_API_TOKEN="owa_k1_YOUR_TOKEN_HERE"

# Optional: override the model (default: google/gemini-2.5-flash-preview-04-17)
OPENROUTER_MODEL=google/gemini-2.5-flash-preview-04-17

# Optional: the system-prompt instructions (defaults to Arabic customer-service prompt)
SYSTEM_PROMPT=
